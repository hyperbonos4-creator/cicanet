// ============================================================
//  CICANET · Schema Prisma — P0 (modelo normalizado del CRM)
//
//  Convenciones:
//  - Tablas en SINGULAR (cliente, servicio, ...) para NO colisionar con
//    las tablas geo de Fase 1 creadas por infra/postgres/init/01-schema.sql
//    (que son plurales: clientes, nodos_red, areas_cobertura...).
//  - Los campos de "estado/tipo" son TEXT (String) — NO enums Prisma — para
//    evitar chocar con los TYPE ... AS ENUM ya creados por el init SQL.
//    La validación vive en los DTO (class-validator) + la máquina de estados.
//  - Geometría: por ahora se guardan lat/lng como Float. La columna PostGIS
//    se añade en P4 (IPAM/topología) vía SQL crudo.
//
//  Sincronización en P0: `prisma db push` (sin historial de migraciones),
//  porque la BD ya tiene tablas administradas por SQL-init. Las migraciones
//  versionadas se formalizan cuando las tablas geo migren bajo Prisma.
// ============================================================

generator client {
  provider      = "prisma-client-js"
  // La imagen corre sobre node:20-alpine (musl + OpenSSL 3). Incluimos el
  // binario del engine para ese target además del nativo del host.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Persona o empresa suscriptora. Bloque 1 del formulario (identificación).
model Cliente {
  id            String   @id @default(uuid()) @db.Uuid
  codigo        String   @unique // CLI-0001 — identificador público visible
  tipoDocumento String   @map("tipo_documento")
  documento     String   @unique
  nombre        String
  tipoCliente   String   @map("tipo_cliente")
  email         String?
  telefonoMovil String?  @map("telefono_movil")
  telefonoFijo  String?  @map("telefono_fijo")

  estado        String   @default("activo") // activo|suspendido|retirado|moroso
  notas         String?
  /// Hash de la clave del portal/app del cliente (login por documento). Si es
  /// null, la clave inicial por defecto es el propio documento.
  claveHash     String?  @map("clave_hash")

  creadoPor     String?  @map("creado_por")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  servicios Servicio[]
  puntos    PuntoInstalacion[]

  @@map("cliente")
}

/// Dirección física de instalación. Bloque 2 del formulario.
model PuntoInstalacion {
  id           String  @id @default(uuid()) @db.Uuid
  clienteId    String  @map("cliente_id") @db.Uuid
  cliente      Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  direccion    String
  barrio       String?
  comuna       String?
  ciudad       String
  departamento String?
  estrato      Int?
  lat          Float?
  lng          Float?
  referencias  String?

  servicios Servicio[]

  @@map("punto_instalacion")
}

/// Catálogo comercial de planes. Se llena/usa en P1 (facturación).
/// En P0 existe la tabla pero los datos del plan viven denormalizados en Servicio.
model Plan {
  id               String  @id @default(uuid()) @db.Uuid
  nombre           String  @unique
  velocidadBajada  Int     @map("velocidad_bajada")
  velocidadSubida  Int     @map("velocidad_subida")
  precio           Decimal @db.Decimal(12, 2)
  iva              Decimal @default(0) @db.Decimal(5, 2)
  tecnologia       String
  activo           Boolean @default(true)
  creadoEn         DateTime @default(now()) @map("creado_en")

  servicios Servicio[]

  @@map("plan")
}

/// La "línea" de internet: conecta cliente + punto + plan. Bloques 3 y 4.
/// Un cliente puede tener varios servicios (1→N), aunque el form crea uno.
model Servicio {
  id        String           @id @default(uuid()) @db.Uuid
  clienteId String           @map("cliente_id") @db.Uuid
  cliente   Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  puntoId   String           @map("punto_id") @db.Uuid
  punto     PuntoInstalacion @relation(fields: [puntoId], references: [id], onDelete: Cascade)
  planId    String?          @map("plan_id") @db.Uuid
  plan      Plan?            @relation(fields: [planId], references: [id])

  // Plan/datos técnicos (bloque 3) — denormalizado en P0
  planNombre      String  @map("plan_nombre")
  velocidadBajada Int?    @map("velocidad_bajada")
  velocidadSubida Int?    @map("velocidad_subida")
  tecnologia      String
  napId           String? @map("nap_id")
  /// FK real a la NAP del inventario (Activo). `napId` (string) se conserva por
  /// compatibilidad; `activoNap` es el vínculo íntegro usado por Customer360.
  activoNapId     String? @map("activo_nap_id")
  activoNap       Activo? @relation("ServicioNap", fields: [activoNapId], references: [id])
  puerto          Int?
  onuSerial       String? @map("onu_serial")
  ip              String?
  vlan            Int?
  usuarioPppoe    String? @map("usuario_pppoe") // se usa en P2 (RADIUS)
  fechaInstalacion DateTime? @map("fecha_instalacion") @db.Date
  estado          String  @default("instalacion_pendiente") // máquina de estados

  // Facturación y contrato (bloque 4) — denormalizado en P0
  cicloFacturacion    String?  @map("ciclo_facturacion")
  diaCorte            Int?     @map("dia_corte")
  metodoPago          String?  @map("metodo_pago")
  tarifa              Decimal? @db.Decimal(12, 2)
  saldo               Decimal? @db.Decimal(12, 2)
  numeroContrato      String?  @map("numero_contrato")
  fechaInicioContrato DateTime? @map("fecha_inicio_contrato") @db.Date
  fechaFinContrato    DateTime? @map("fecha_fin_contrato") @db.Date

  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  facturas Factura[]

  @@map("servicio")
}

/// Esqueleto de factura — se desarrolla en P1.
model Factura {
  id               String   @id @default(uuid()) @db.Uuid
  servicioId       String   @map("servicio_id") @db.Uuid
  servicio         Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  periodo          String // "2026-06"
  subtotal         Decimal  @db.Decimal(12, 2)
  iva              Decimal  @default(0) @db.Decimal(12, 2)
  total            Decimal  @db.Decimal(12, 2)
  estado           String   @default("pendiente") // pendiente|pagada|vencida|anulada
  fechaEmision     DateTime @map("fecha_emision") @db.Date
  fechaVencimiento DateTime @map("fecha_vencimiento") @db.Date
  pdfUrl           String?  @map("pdf_url")
  creadoEn         DateTime @default(now()) @map("creado_en")

  pagos Pago[]

  /// Idempotencia de la facturación recurrente: una factura por servicio y periodo.
  @@unique([servicioId, periodo])
  @@index([estado])
  @@map("factura")
}

/// Esqueleto de pago — se desarrolla en P3.
model Pago {
  id                String   @id @default(uuid()) @db.Uuid
  facturaId         String   @map("factura_id") @db.Uuid
  factura           Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  monto             Decimal  @db.Decimal(12, 2)
  metodo            String // wompi|efectivo|transferencia|...
  referenciaExterna String?  @unique @map("referencia_externa") // idempotencia
  estado            String   @default("pendiente") // aprobado|rechazado|pendiente
  pagadoEn          DateTime? @map("pagado_en")
  creadoEn          DateTime @default(now()) @map("creado_en")

  @@map("pago")
}

/// Transacción de pasarela (Wompi). Fuente de verdad del ciclo de pago en línea,
/// desacoplada de la facturación (P1): existe aunque aún no haya factura formal.
/// Cuando hay factura, se enlaza (facturaId) y al aprobarse se marca pagada.
model PagoTransaccion {
  id            String   @id @default(uuid()) @db.Uuid
  /// Referencia única que enviamos a Wompi (idempotencia).
  referencia    String   @unique
  proveedor     String   @default("wompi")
  /// Id de la transacción en Wompi (se llena al confirmar).
  proveedorTxId String?  @map("proveedor_tx_id")
  montoCents    Int      @map("monto_cents")
  moneda        String   @default("COP")
  /// CREADA | PENDIENTE | APROBADA | RECHAZADA | ANULADA | ERROR
  estado        String   @default("CREADA")
  metodo        String? // PSE | NEQUI | CARD | BANCOLOMBIA_TRANSFER | ...
  descripcion   String?
  emailCliente  String?  @map("email_cliente")
  facturaId     String?  @map("factura_id") @db.Uuid
  clienteId     String?  @map("cliente_id") @db.Uuid
  creadoPor     String?  @map("creado_por")
  datosWompi    Json?    @map("datos_wompi") @db.JsonB
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  @@map("pago_transaccion")
}

/// Ticket de soporte (lo puede crear el asistente "Cica" o el staff).
model Ticket {
  id          String   @id @default(uuid()) @db.Uuid
  codigo      String   @unique // TCK-XXXX visible
  asunto      String
  descripcion String
  categoria   String   @default("general") // tecnico|facturacion|comercial|general
  contacto    String? // nombre/teléfono que dejó el cliente
  estado      String   @default("abierto") // abierto|en_proceso|resuelto|cerrado
  origen      String   @default("asistente") // asistente|panel|whatsapp
  creadoPor   String?  @map("creado_por") // username de quien lo originó (cliente/staff)
  clienteId   String?  @map("cliente_id") @db.Uuid
  creadoEn    DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  @@index([estado])
  @@map("ticket")
}

/// Orden de trabajo de campo (instalación / visita / reparación). El admin u
/// operador la crea y la asigna a un técnico (por su username); el técnico la
/// gestiona desde su apartado en la app móvil: cambia el estado, adjunta fotos
/// de evidencia (capturadas con la cámara) y la completa con notas. El admin NO
/// sube fotos: la evidencia la genera el técnico en sitio.
model OrdenTrabajo {
  id              String   @id @default(uuid()) @db.Uuid
  codigo          String   @unique // OT-XXXX visible
  tipo            String   @default("instalacion") // instalacion|visita|reparacion
  estado          String   @default("asignada") // asignada|en_camino|en_sitio|completada|cancelada
  prioridad       String   @default("media") // baja|media|alta

  titulo          String
  descripcion     String?
  direccion       String
  lat             Float?
  lng             Float?

  /// Username del técnico asignado (rol `tecnico`). null = sin asignar.
  tecnico         String?
  /// Vínculo opcional al cliente (UUID). La OT puede existir antes del alta.
  clienteId       String?  @map("cliente_id") @db.Uuid
  clienteNombre   String?  @map("cliente_nombre")
  contacto        String? // teléfono/nombre de contacto en sitio

  fechaProgramada DateTime? @map("fecha_programada")
  notasTecnico    String?  @map("notas_tecnico")
  /// Evidencia fotográfica: [{ id, url, nota, ts }]. La suben los técnicos.
  fotos           Json?    @db.JsonB
  /// Bitácora de cambios de estado: [{ estado, ts, por }].
  historial       Json?    @db.JsonB

  creadoPor       String?  @map("creado_por")
  creadoEn        DateTime @default(now()) @map("creado_en")
  completadaEn    DateTime? @map("completada_en")
  actualizadoEn   DateTime? @updatedAt @map("actualizado_en")

  @@index([tecnico])
  @@index([estado])
  @@map("orden_trabajo")
}

/// Configuración clave/valor de la plataforma (editable desde el panel admin).
/// Ej.: "soporte_whatsapp" → { numero, mensaje, habilitado }. Reutilizable para
/// futuras configuraciones (config_facturacion, etc.) sin nuevas migraciones.
model Setting {
  clave         String   @id
  valor         Json     @db.JsonB
  actualizadoPor String? @map("actualizado_por")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("setting")
}

/// Bitácora de auditoría: todo cambio sensible (quién, qué, cuándo).
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actor     String? // username del staff (del JWT)
  accion    String // create|update|delete
  entidad   String // "cliente", ...
  entidadId String?  @map("entidad_id")
  diff      Json?    @db.JsonB
  ts        DateTime @default(now())

  @@index([entidad, entidadId])
  @@map("audit_log")
}

// ============================================================
//  Gemelo Digital de la Red (network-digital-twin) — inventario en Postgres.
//  Migrado desde JSON (infra-*.json) a la BD para integridad, transacciones y
//  fuente de verdad única junto al CRM. La geometría se guarda como lat/lng
//  (Float) + trazado (Json); las columnas PostGIS/índices GIST se añaden cuando
//  se muevan las consultas espaciales del JS al motor. Ids con prefijo de
//  dominio (NAP-001, POP-001, FIB-001) — públicos y estables.
// ============================================================

/// Activo de red/planta: POP, OLT, NAP, Splitter, Cliente, etc. Ficha universal.
model Activo {
  id            String   @id // NAP-001, POP-001, ...
  tipo          String
  nombre        String
  marca         String?
  modelo        String?
  serie         String?
  direccion     String?
  barrio        String?
  comuna        String?
  ciudad        String?
  lat           Float
  lng           Float
  estado        String   @default("Activo")
  propio        Boolean  @default(true)
  regimen       String?
  /// Topología: de qué activo depende (grafo padre→hijo).
  padreId       String?  @map("padre_id")
  sitioId       String?  @map("sitio_id")
  /// Plan mensual (COP) cuando el activo es un Cliente — base de ingresos.
  planMensual   Float?   @map("plan_mensual")
  /// Atributos por tipo (puertosTotal/Usados de NAP, etc.).
  atributos     Json?    @db.JsonB
  /// Evidencia fotográfica [{ id, categoria, url, subidoEn, autor }].
  fotos         Json?    @db.JsonB
  documentos    Json?    @db.JsonB
  historial     Json?    @db.JsonB
  creadoPor     String?  @map("creado_por")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  /// Servicios (clientes) conectados a este activo cuando es una NAP/CTO.
  serviciosNap  Servicio[] @relation("ServicioNap")

  @@index([tipo])
  @@index([padreId])
  @@map("activo")
}

/// Segmento de fibra: trayecto físico entre dos puntos/activos.
model SegmentoFibra {
  id               String   @id // FIB-001
  nombre           String?
  tipoFibra        String?  @map("tipo_fibra")
  hilos            Int?
  origenId         String?  @map("origen_id")
  destinoId        String?  @map("destino_id")
  origenDireccion  String?  @map("origen_direccion")
  destinoDireccion String?  @map("destino_direccion")
  origenLng        Float    @map("origen_lng")
  origenLat        Float    @map("origen_lat")
  destinoLng       Float    @map("destino_lng")
  destinoLat       Float    @map("destino_lat")
  /// Trazado [[lng,lat], ...].
  trazado          Json?    @db.JsonB
  longitud         Float // metros
  creadoPor        String?  @map("creado_por")
  creadoEn         DateTime @default(now()) @map("creado_en")

  @@map("segmento_fibra")
}

/// Sitio físico (POP, nodo, gabinete) que agrupa activos.
model Sitio {
  id         String   @id // SITE-001
  nombre     String
  lat        Float
  lng        Float
  activosIds Json?    @map("activos_ids") @db.JsonB
  creadoEn   DateTime @default(now()) @map("creado_en")

  @@map("sitio")
}

// ============================================================
//  CONTABILIDAD (módulo accounting) — ledger de doble partida para CICANET.
//
//  Principios (no negociables, validados por el servicio):
//  - Toda transacción es un AsientoContable con N MovimientoContable cuya suma
//    de débitos == suma de créditos (cuadre exacto), escrito atómicamente.
//  - Un asiento "contabilizado" es INMUTABLE: no se edita, se REVERSA.
//  - El periodo se puede CERRAR (bloquea asientos con fecha dentro del periodo).
//  - Los saldos se DERIVAN de los movimientos (la verdad son las líneas).
//  - Plan de cuentas = PUC Colombia (Decreto 2650): clases 1..9.
// ============================================================

/// Cuenta del Plan Único de Cuentas (PUC Colombia). Estructura jerárquica por
/// longitud de código: 1=clase, 2=grupo, 4=cuenta, 6=subcuenta, 8+=auxiliar.
/// Solo las cuentas `imputable=true` reciben movimientos (las de título no).
model CuentaContable {
  codigo        String   @id // 110505, 413505, ... (PUC)
  nombre        String
  /// Clase PUC (1=Activo,2=Pasivo,3=Patrimonio,4=Ingreso,5=Gasto,6=Costo venta,7=Costo prod,8=Orden deudoras,9=Orden acreedoras)
  clase         Int
  /// Naturaleza del saldo normal: 'debito' | 'credito'.
  naturaleza    String
  /// Nivel jerárquico: clase|grupo|cuenta|subcuenta|auxiliar.
  nivel         String
  /// Código de la cuenta padre (para armar el árbol).
  padreCodigo   String?  @map("padre_codigo")
  /// Solo las imputables reciben movimientos; las de título agregan saldos.
  imputable     Boolean  @default(false)
  /// Exige tercero (NIT/cédula) al mover esta cuenta (clientes, proveedores).
  exigeTercero  Boolean  @default(false) @map("exige_tercero")
  /// Exige centro de costo al mover esta cuenta.
  exigeCentro   Boolean  @default(false) @map("exige_centro")
  activa        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")

  movimientos   MovimientoContable[]

  @@index([clase])
  @@index([padreCodigo])
  @@map("cuenta_contable")
}

/// Tercero contable (cliente, proveedor, empleado, otro). Para auxiliares por NIT.
model Tercero {
  id            String   @id @default(uuid()) @db.Uuid
  tipoDocumento String   @default("CC") @map("tipo_documento")
  documento     String   @unique
  dv            String?  // dígito de verificación (NIT)
  nombre        String
  tipo          String   @default("cliente") // cliente|proveedor|empleado|otro
  email         String?
  telefono      String?
  /// Vínculo opcional al cliente del CRM (si el tercero es un suscriptor).
  clienteId     String?  @map("cliente_id") @db.Uuid
  creadoEn      DateTime @default(now()) @map("creado_en")

  movimientos   MovimientoContable[]

  @@map("tercero")
}

/// Periodo contable mensual (YYYY-MM). Al cerrarse bloquea asientos del periodo.
model PeriodoContable {
  periodo     String   @id // "2026-06"
  estado      String   @default("abierto") // abierto|cerrado
  cerradoPor  String?  @map("cerrado_por")
  cerradoEn   DateTime? @map("cerrado_en")
  creadoEn    DateTime @default(now()) @map("creado_en")

  @@map("periodo_contable")
}

/// Asiento contable (comprobante). Cabecera del registro de doble partida.
model AsientoContable {
  id            String   @id @default(uuid()) @db.Uuid
  numero        String   @unique // CMP-000001 (consecutivo)
  fecha         DateTime @db.Date
  periodo       String // "2026-06" (derivado de fecha)
  /// Tipo de comprobante: manual|apertura|venta|recaudo|compra|gasto|ajuste|depreciacion|cierre|reversion
  tipo          String   @default("manual")
  descripcion   String
  /// Origen: qué evento del negocio lo generó (factura, pago, etc.).
  referenciaTipo String? @map("referencia_tipo")
  referenciaId   String? @map("referencia_id")
  /// Trazabilidad ampliada (v2 — Fase B). Módulo que originó el asiento.
  sourceModule  String?  @map("source_module")
  /// Evento de negocio que lo disparó (invoice.issued, payment.received, ...).
  evento        String?
  /// true = generado automáticamente por el posting engine; false = manual.
  autoGenerado  Boolean  @default(false) @map("auto_generado")
  /// Dimensiones operativas para drill-down (cartera/rentabilidad georreferenciada).
  napId         String?  @map("nap_id")
  zonaId        String?  @map("zona_id")
  servicioId    String?  @map("servicio_id") @db.Uuid
  clienteId     String?  @map("cliente_id") @db.Uuid
  /// Documento DIAN relacionado, si lo hay.
  dianDocumentoId String? @map("dian_documento_id") @db.Uuid
  /// borrador|contabilizado|anulado
  estado        String   @default("borrador")
  debitoTotal   Decimal  @default(0) @db.Decimal(16, 2) @map("debito_total")
  creditoTotal  Decimal  @default(0) @db.Decimal(16, 2) @map("credito_total")
  /// Si este asiento reversa a otro (inmutabilidad: no se edita, se reversa).
  reversaDeId   String?  @map("reversa_de_id") @db.Uuid
  creadoPor     String?  @map("creado_por")
  contabilizadoPor String? @map("contabilizado_por")
  contabilizadoEn  DateTime? @map("contabilizado_en")
  creadoEn      DateTime @default(now()) @map("creado_en")

  movimientos   MovimientoContable[]

  @@index([periodo])
  @@index([estado])
  @@index([referenciaTipo, referenciaId])
  @@index([sourceModule])
  @@index([clienteId])
  @@index([napId])
  @@map("asiento_contable")
}

/// Movimiento (línea) del asiento: un débito o un crédito sobre una cuenta.
model MovimientoContable {
  id          String   @id @default(uuid()) @db.Uuid
  asientoId   String   @map("asiento_id") @db.Uuid
  asiento     AsientoContable @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  cuentaCodigo String  @map("cuenta_codigo")
  cuenta      CuentaContable @relation(fields: [cuentaCodigo], references: [codigo])
  descripcion String?
  debito      Decimal  @default(0) @db.Decimal(16, 2)
  credito     Decimal  @default(0) @db.Decimal(16, 2)
  terceroId   String?  @map("tercero_id") @db.Uuid
  tercero     Tercero? @relation(fields: [terceroId], references: [id])
  centroCosto String?  @map("centro_costo")
  orden       Int      @default(0)

  @@index([asientoId])
  @@index([cuentaCodigo])
  @@index([terceroId])
  @@map("movimiento_contable")
}

/// Documento electrónico DIAN emitido (factura/nota) vía el microservicio einvoice.
/// Es el registro fiscal; la contabilidad NO se reconstruye del XML: el asiento
/// se genera en el ledger y se enlaza aquí (asientoId).
model DianDocumento {
  id            String   @id @default(uuid()) @db.Uuid
  tipo          String   @default("factura") // factura|nota_credito|nota_debito|documento_soporte
  consecutivo   String   // prefijo+numero (ej. FE-1001)
  cufe          String?  // CUFE/CUDE devuelto por la DIAN
  estado        String   @default("pendiente") // pendiente|enviada|aceptada|rechazada|error
  ambiente      String   @default("habilitacion") // habilitacion|produccion
  /// Cliente del CRM al que se le facturó (opcional).
  clienteId     String?  @map("cliente_id") @db.Uuid
  /// Factura interna de CICANET asociada (opcional).
  facturaId     String?  @map("factura_id") @db.Uuid
  /// Asiento contable que registró el ingreso (enlace al ledger).
  asientoId     String?  @map("asiento_id") @db.Uuid
  subtotal      Decimal  @default(0) @db.Decimal(16, 2)
  iva           Decimal  @default(0) @db.Decimal(16, 2)
  total         Decimal  @default(0) @db.Decimal(16, 2)
  /// Errores/mensajes devueltos por la DIAN.
  mensajes      Json?    @db.JsonB
  /// XML firmado (base64) y datos crudos de la respuesta DIAN.
  xmlBase64     String?  @map("xml_base64")
  emitidoPor    String?  @map("emitido_por")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  @@index([clienteId])
  @@index([estado])
  @@map("dian_documento")
}

/// Cuenta bancaria de CICANET, mapeada a una cuenta PUC del disponible (11xx).
model CuentaBancaria {
  id          String   @id @default(uuid()) @db.Uuid
  nombre      String   // "Bancolombia corriente"
  banco       String?
  numero      String?
  cuentaPuc   String   @map("cuenta_puc") // 111005, 111010...
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now()) @map("creado_en")

  movimientos MovimientoBancario[]

  @@map("cuenta_bancaria")
}

/// Movimiento de extracto bancario importado (entrada + / salida −).
model MovimientoBancario {
  id               String   @id @default(uuid()) @db.Uuid
  cuentaBancariaId String   @map("cuenta_bancaria_id") @db.Uuid
  cuentaBancaria   CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id], onDelete: Cascade)
  fecha            DateTime @db.Date
  descripcion      String
  referencia       String?
  /// Valor con signo: positivo = entrada (crédito banco), negativo = salida.
  valor            Decimal  @db.Decimal(16, 2)
  /// sin_conciliar | conciliado | ignorado
  estado           String   @default("sin_conciliar")
  /// Hash para deduplicar en reimportaciones (cuenta+fecha+valor+ref+desc).
  hash             String   @unique
  /// Asiento contable generado al conciliar.
  asientoId        String?  @map("asiento_id") @db.Uuid
  /// Recaudo (PagoTransaccion) con el que se concilió, si aplica.
  matchPagoTxId    String?  @map("match_pago_tx_id")
  conciliadoPor    String?  @map("conciliado_por")
  conciliadoEn     DateTime? @map("conciliado_en")
  creadoEn         DateTime @default(now()) @map("creado_en")

  @@index([estado])
  @@index([cuentaBancariaId])
  @@map("movimiento_bancario")
}

/// Bitácora de envíos de cobranza (dunning). Garantiza idempotencia: un recordatorio
/// por (cliente, bucket, mes). Evita spamear al cliente.
model DunningEnvio {
  id          String   @id @default(uuid()) @db.Uuid
  clienteId   String   @map("cliente_id") @db.Uuid
  bucket      String   // d1_30|d31_60|d61_90|d90mas
  periodoMes  String   @map("periodo_mes") // "2026-06" (mes del envío)
  canal       String   @default("whatsapp") // whatsapp|email
  destino     String?
  mensaje     String?
  estado      String   @default("enviado") // enviado|fallido|simulado
  error       String?
  creadoEn    DateTime @default(now()) @map("creado_en")

  @@unique([clienteId, bucket, periodoMes])
  @@index([periodoMes])
  @@map("dunning_envio")
}

/// Factura de compra / causación de gasto (cuentas por pagar). El proveedor es
/// un Tercero. Soporta varias líneas de gasto/activo + IVA descontable y las
/// retenciones que CICANET practica (retefuente/reteIVA/reteICA). La causación y
/// el pago generan asientos en el ledger (la verdad contable es el asiento).
model FacturaCompra {
  id              String   @id @default(uuid()) @db.Uuid
  numero          String   @unique // CXP-000001 (consecutivo interno)
  /// Número de la factura del proveedor (referencia externa).
  numeroProveedor String?  @map("numero_proveedor")
  proveedorId     String   @map("proveedor_id") @db.Uuid
  proveedorNombre String   @map("proveedor_nombre")
  fecha           DateTime @db.Date
  fechaVencimiento DateTime @db.Date @map("fecha_vencimiento")
  concepto        String
  /// Líneas: [{ cuenta, descripcion, base, ivaPct }].
  lineas          Json     @db.JsonB
  subtotal        Decimal  @default(0) @db.Decimal(16, 2)
  ivaDescontable  Decimal  @default(0) @db.Decimal(16, 2) @map("iva_descontable")
  retefuente      Decimal  @default(0) @db.Decimal(16, 2)
  reteIva         Decimal  @default(0) @db.Decimal(16, 2) @map("rete_iva")
  reteIca         Decimal  @default(0) @db.Decimal(16, 2) @map("rete_ica")
  /// Neto a pagar = subtotal + IVA − retenciones.
  totalAPagar     Decimal  @default(0) @db.Decimal(16, 2) @map("total_a_pagar")
  /// pendiente | pagada | anulada
  estado          String   @default("pendiente")
  /// Fecha programada de pago (tesorería / agenda de la contadora).
  fechaPagoProgramada DateTime? @db.Date @map("fecha_pago_programada")
  asientoId       String?  @map("asiento_id") @db.Uuid
  asientoPagoId   String?  @map("asiento_pago_id") @db.Uuid
  /// Si se emitió documento soporte electrónico (no obligado a facturar).
  documentoSoporte Boolean @default(false) @map("documento_soporte")
  creadoPor       String?  @map("creado_por")
  creadoEn        DateTime @default(now()) @map("creado_en")
  pagadaEn        DateTime? @map("pagada_en")

  @@index([estado])
  @@index([proveedorId])
  @@map("factura_compra")
}

/// Regla de impuesto/retención parametrizable (la contadora la ajusta cada año).
/// El motor calcula IVA y retenciones (retefuente/reteIVA/reteICA) respetando la
/// base mínima, para no digitarlos a mano.
model ReglaImpuesto {
  codigo       String   @id // rf_compras, rf_servicios, iva_19, reteiva, reteica...
  tipo         String   // iva | retefuente | reteiva | reteica
  nombre       String
  porcentaje   Decimal  @db.Decimal(8, 4)
  /// Base mínima en COP para aplicar (0 = siempre). La contadora la actualiza por UVT.
  baseMinima   Decimal  @default(0) @db.Decimal(16, 2) @map("base_minima")
  /// Cuenta PUC donde se acredita el impuesto/retención.
  cuentaPuc    String   @map("cuenta_puc")
  activa       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")

  @@map("regla_impuesto")
}

/// Activo fijo depreciable (OLT, switches, NAP, vehículos, equipos). La
/// depreciación mensual genera un asiento (Dr gasto, Cr depreciación acumulada).
model ActivoFijo {
  id                  String   @id @default(uuid()) @db.Uuid
  nombre              String
  cuentaActivo        String   @default("152805") @map("cuenta_activo")
  cuentaDepAcum       String   @default("159205") @map("cuenta_dep_acum")
  cuentaGasto         String   @default("516005") @map("cuenta_gasto")
  valorAdquisicion    Decimal  @db.Decimal(16, 2) @map("valor_adquisicion")
  valorResidual       Decimal  @default(0) @db.Decimal(16, 2) @map("valor_residual")
  fechaAdquisicion    DateTime @db.Date @map("fecha_adquisicion")
  vidaUtilMeses       Int      @map("vida_util_meses")
  depreciacionAcumulada Decimal @default(0) @db.Decimal(16, 2) @map("depreciacion_acumulada")
  estado              String   @default("activo") // activo | depreciado | baja
  creadoEn            DateTime @default(now()) @map("creado_en")

  registros           DepreciacionRegistro[]

  @@map("activo_fijo")
}

/// Registro de depreciación de un activo en un periodo (idempotencia mensual).
model DepreciacionRegistro {
  id           String   @id @default(uuid()) @db.Uuid
  activoFijoId String   @map("activo_fijo_id") @db.Uuid
  activoFijo   ActivoFijo @relation(fields: [activoFijoId], references: [id], onDelete: Cascade)
  periodo      String   // "2026-06"
  valor        Decimal  @db.Decimal(16, 2)
  asientoId    String?  @map("asiento_id") @db.Uuid
  creadoEn     DateTime @default(now()) @map("creado_en")

  @@unique([activoFijoId, periodo])
  @@map("depreciacion_registro")
}

/// Empleado para nómina. Maestro mínimo (la liquidación calcula salud/pensión).
model Empleado {
  id               String   @id @default(uuid()) @db.Uuid
  nombre           String
  documento        String   @unique
  tipoDocumento    String   @default("CC") @map("tipo_documento")
  cargo            String?
  salarioBase      Decimal  @db.Decimal(16, 2) @map("salario_base")
  fechaIngreso     DateTime @db.Date @map("fecha_ingreso")
  email            String?
  estado           String   @default("activo") // activo | retirado
  creadoEn         DateTime @default(now()) @map("creado_en")

  liquidaciones    LiquidacionNomina[]

  @@map("empleado")
}

/// Liquidación de nómina de un empleado en un periodo (idempotente por empleado+periodo).
model LiquidacionNomina {
  id               String   @id @default(uuid()) @db.Uuid
  empleadoId       String   @map("empleado_id") @db.Uuid
  empleado         Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  periodo          String   // "2026-06"
  /// Detalle [{ concepto, valor }].
  devengados       Json     @db.JsonB
  deducciones      Json     @db.JsonB
  totalDevengado   Decimal  @db.Decimal(16, 2) @map("total_devengado")
  totalDeducciones Decimal  @db.Decimal(16, 2) @map("total_deducciones")
  neto             Decimal  @db.Decimal(16, 2)
  asientoId        String?  @map("asiento_id") @db.Uuid
  /// Si se emitió el documento de nómina electrónica ante la DIAN.
  documentoElectronico Boolean @default(false) @map("documento_electronico")
  creadoEn         DateTime @default(now()) @map("creado_en")

  @@unique([empleadoId, periodo])
  @@map("liquidacion_nomina")
}

/// Recibo de caja (cash receipt): dinero recibido de un cliente (o sin identificar),
/// que se aplica a una o varias facturas. Maneja abonos parciales, pagos múltiples,
/// anticipos (saldo a favor) y recaudos por identificar. Genera el asiento de recaudo.
model ReciboCaja {
  id              String   @id @default(uuid()) @db.Uuid
  numero          String   @unique // REC-000001
  fecha           DateTime @db.Date
  clienteId       String?  @map("cliente_id") @db.Uuid
  clienteNombre   String?  @map("cliente_nombre")
  medioPago       String   @map("medio_pago") // efectivo|transferencia|wompi|nequi|consignacion|tarjeta
  cuentaDestino   String   @map("cuenta_destino") // PUC 11xx (banco/caja)
  referencia      String?
  montoRecibido   Decimal  @db.Decimal(16, 2) @map("monto_recibido")
  montoAplicado   Decimal  @default(0) @db.Decimal(16, 2) @map("monto_aplicado")
  saldoPorAplicar Decimal  @default(0) @db.Decimal(16, 2) @map("saldo_por_aplicar")
  /// Cuenta donde queda el saldo sin aplicar: 280505 (anticipo) o 280515 (por identificar).
  cuentaSaldo     String?  @map("cuenta_saldo")
  /// sin_aplicar | parcial | aplicado | anulado
  estado          String   @default("sin_aplicar")
  origen          String   @default("manual") // manual|wompi|conciliacion
  asientoId       String?  @map("asiento_id") @db.Uuid
  creadoPor       String?  @map("creado_por")
  creadoEn        DateTime @default(now()) @map("creado_en")

  aplicaciones    AplicacionPago[]

  @@index([estado])
  @@index([clienteId])
  @@map("recibo_caja")
}

/// Aplicación de un recibo de caja a una factura concreta (detalle de cartera).
model AplicacionPago {
  id          String   @id @default(uuid()) @db.Uuid
  reciboId    String   @map("recibo_id") @db.Uuid
  recibo      ReciboCaja @relation(fields: [reciboId], references: [id], onDelete: Cascade)
  facturaId   String   @map("factura_id") @db.Uuid
  monto       Decimal  @db.Decimal(16, 2)
  /// Asiento de reclasificación (cuando se aplica un saldo ya recibido). null si fue en la creación.
  asientoId   String?  @map("asiento_id") @db.Uuid
  creadoEn    DateTime @default(now()) @map("creado_en")

  @@index([reciboId])
  @@index([facturaId])
  @@map("aplicacion_pago")
}

/// Movimiento de tesorería: egreso directo, traslado entre cuentas, comisión
/// bancaria/GMF. Cada uno genera su asiento. Caja menor = egreso desde 110510.
model MovimientoTesoreria {
  id            String   @id @default(uuid()) @db.Uuid
  numero        String   @unique // TES-000001
  tipo          String   // egreso | traslado | comision | ingreso_otro
  fecha         DateTime @db.Date
  cuentaOrigen  String?  @map("cuenta_origen")   // banco/caja de salida (egreso/traslado/comision)
  cuentaDestino String?  @map("cuenta_destino")  // banco/caja de entrada (traslado/ingreso)
  contraCuenta  String?  @map("contra_cuenta")   // gasto/ingreso (egreso/comision/ingreso_otro)
  monto         Decimal  @db.Decimal(16, 2)
  concepto      String
  beneficiario  String?
  asientoId     String?  @map("asiento_id") @db.Uuid
  creadoPor     String?  @map("creado_por")
  creadoEn      DateTime @default(now()) @map("creado_en")

  @@index([tipo])
  @@map("movimiento_tesoreria")
}

/// Acuerdo de pago / refinanciación de cartera de un cliente moroso. Plan de
/// cuotas que se cruza con los recaudos (cash application). No genera asiento por
/// sí mismo; los pagos siguen su flujo normal de recibo de caja.
model AcuerdoPago {
  id            String   @id @default(uuid()) @db.Uuid
  numero        String   @unique // ACU-000001
  clienteId     String   @map("cliente_id") @db.Uuid
  clienteNombre String   @map("cliente_nombre")
  fechaAcuerdo  DateTime @db.Date @map("fecha_acuerdo")
  montoTotal    Decimal  @db.Decimal(16, 2) @map("monto_total")
  numeroCuotas  Int      @map("numero_cuotas")
  periodicidad  String   @default("mensual") // mensual | quincenal
  /// Cuotas [{ n, fecha, valor, estado }].
  cuotas        Json     @db.JsonB
  estado        String   @default("vigente") // vigente | cumplido | incumplido | cancelado
  notas         String?
  creadoPor     String?  @map("creado_por")
  creadoEn      DateTime @default(now()) @map("creado_en")

  @@index([clienteId])
  @@index([estado])
  @@map("acuerdo_pago")
}

// ============================================================
//  v2 — Endurecimiento del core financiero-operativo
//  Centros de costo, inventario de red operativo, mapeo exógena.
// ============================================================

/// Centro de costo (entidad de 1er nivel para analítica vertical de ISP).
/// Permite imputar gastos/ingresos a admin/soporte/instalación/backbone/nodo y
/// medir rentabilidad por área. Las líneas de asiento referencian `codigo`.
model CentroCosto {
  codigo    String   @id // CC-ADMIN, CC-RED, CC-NODO-01...
  nombre    String
  tipo      String   @default("operativo") // administrativo | operativo | comercial | red | nodo
  /// Centro padre opcional (jerarquía: zona → nodo).
  padreCodigo String? @map("padre_codigo")
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([tipo])
  @@map("centro_costo")
}

/// Inventario operativo de activo de red (≠ activo fijo contable). Seriales,
/// MAC, comodato, stock y ubicación. Se vincula opcionalmente al activo contable
/// (`activoFijoId`) para depreciación y al servicio/cliente que lo usa.
model AssetRegistry {
  id            String   @id @default(uuid()) @db.Uuid
  codigo        String   @unique // AR-000001
  categoria     String   // onu | router | switch | olt | nap | antena | otro
  marca         String?
  modelo        String?
  serial        String?  @unique
  mac           String?
  /// disponible | asignado | comodato | dañado | baja | stock
  estado        String   @default("stock")
  ubicacion     String?  // bodega | NAP-001 | dirección del cliente
  /// Servicio/cliente al que está asignado (comodato), si aplica.
  servicioId    String?  @map("servicio_id") @db.Uuid
  clienteId     String?  @map("cliente_id") @db.Uuid
  napId         String?  @map("nap_id")
  /// Vínculo al activo fijo contable depreciable (si está capitalizado).
  activoFijoId  String?  @map("activo_fijo_id") @db.Uuid
  comodato      Boolean  @default(false) // entregado en comodato al cliente
  costo         Decimal? @db.Decimal(16, 2)
  notas         String?
  creadoPor     String?  @map("creado_por")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  @@index([estado])
  @@index([categoria])
  @@index([servicioId])
  @@map("asset_registry")
}

/// Regla de mapeo para información exógena: relaciona un patrón de cuenta PUC con
/// el concepto/formato DIAN. Parametrizable por la contadora (Fase E).
model ReglaExogena {
  id          String   @id @default(uuid()) @db.Uuid
  formato     String   // 1001 | 1003 | 1005 | 1006 | 1007 | 1008 | 1009
  /// Patrón de cuenta (prefijo PUC, ej. "5135" cubre 5135xx).
  cuentaPatron String  @map("cuenta_patron")
  concepto    String   // concepto DIAN (ej. 5016 honorarios)
  descripcion String?
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now()) @map("creado_en")

  @@unique([formato, cuentaPatron])
  @@index([formato])
  @@map("regla_exogena")
}

/// Cargo recurrente adicional de un servicio (Fase III.3.C): IP fija, TV/OTT,
/// arriendo de router/ONU, reconexión, instalación financiada, descuentos (monto
/// negativo). La facturación recurrente los suma a la tarifa del plan cada ciclo.
model CargoRecurrente {
  id            String   @id @default(uuid()) @db.Uuid
  servicioId    String   @map("servicio_id") @db.Uuid
  concepto      String
  /// Cuenta PUC de ingreso (o de menor ingreso si es descuento).
  cuentaIngreso String   @default("414505") @map("cuenta_ingreso")
  /// Monto mensual (puede ser negativo para descuentos recurrentes).
  monto         Decimal  @db.Decimal(12, 2)
  ivaPct        Decimal  @default(0) @db.Decimal(5, 2) @map("iva_pct")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")

  @@index([servicioId])
  @@map("cargo_recurrente")
}

/// Solicitud de "hablar con un asesor" (handoff bot → humano). La crea el asistente
/// cuando el cliente pide atención humana; aparece en el panel de WhatsApp para que
/// un agente la atienda (abriendo wa.me hacia el número del cliente, sin el historial
/// del bot). El historial con el bot NO se traslada (privacidad + conversación limpia).
model SolicitudAsesor {
  id          String   @id @default(uuid()) @db.Uuid
  clienteId   String?  @map("cliente_id") @db.Uuid
  nombre      String?
  telefono    String?  // dígitos E.164 (ej. 573001234567)
  motivo      String?
  /// pendiente | atendida | cerrada
  estado      String   @default("pendiente")
  origen      String   @default("bot") // bot | panel | app
  canal       String   @default("whatsapp")
  atendidoPor String?  @map("atendido_por")
  creadoEn    DateTime @default(now()) @map("creado_en")
  atendidoEn  DateTime? @map("atendido_en")

  @@index([estado])
  @@map("solicitud_asesor")
}
