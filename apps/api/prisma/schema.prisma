// ============================================================
//  CICANET · Schema Prisma — P0 (modelo normalizado del CRM)
//
//  Convenciones:
//  - Tablas en SINGULAR (cliente, servicio, ...) para NO colisionar con
//    las tablas geo de Fase 1 creadas por infra/postgres/init/01-schema.sql
//    (que son plurales: clientes, nodos_red, areas_cobertura...).
//  - Los campos de "estado/tipo" son TEXT (String) — NO enums Prisma — para
//    evitar chocar con los TYPE ... AS ENUM ya creados por el init SQL.
//    La validación vive en los DTO (class-validator) + la máquina de estados.
//  - Geometría: por ahora se guardan lat/lng como Float. La columna PostGIS
//    se añade en P4 (IPAM/topología) vía SQL crudo.
//
//  Sincronización en P0: `prisma db push` (sin historial de migraciones),
//  porque la BD ya tiene tablas administradas por SQL-init. Las migraciones
//  versionadas se formalizan cuando las tablas geo migren bajo Prisma.
// ============================================================

generator client {
  provider      = "prisma-client-js"
  // La imagen corre sobre node:20-alpine (musl + OpenSSL 3). Incluimos el
  // binario del engine para ese target además del nativo del host.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Persona o empresa suscriptora. Bloque 1 del formulario (identificación).
model Cliente {
  id            String   @id @default(uuid()) @db.Uuid
  codigo        String   @unique // CLI-0001 — identificador público visible
  tipoDocumento String   @map("tipo_documento")
  documento     String   @unique
  nombre        String
  tipoCliente   String   @map("tipo_cliente")
  email         String?
  telefonoMovil String?  @map("telefono_movil")
  telefonoFijo  String?  @map("telefono_fijo")

  estado        String   @default("activo") // activo|suspendido|retirado|moroso
  notas         String?
  /// Hash de la clave del portal/app del cliente (login por documento). Si es
  /// null, la clave inicial por defecto es el propio documento.
  claveHash     String?  @map("clave_hash")

  creadoPor     String?  @map("creado_por")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  servicios Servicio[]
  puntos    PuntoInstalacion[]

  @@map("cliente")
}

/// Dirección física de instalación. Bloque 2 del formulario.
model PuntoInstalacion {
  id           String  @id @default(uuid()) @db.Uuid
  clienteId    String  @map("cliente_id") @db.Uuid
  cliente      Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  direccion    String
  barrio       String?
  comuna       String?
  ciudad       String
  departamento String?
  estrato      Int?
  lat          Float?
  lng          Float?
  referencias  String?

  servicios Servicio[]

  @@map("punto_instalacion")
}

/// Catálogo comercial de planes. Se llena/usa en P1 (facturación).
/// En P0 existe la tabla pero los datos del plan viven denormalizados en Servicio.
model Plan {
  id               String  @id @default(uuid()) @db.Uuid
  nombre           String  @unique
  velocidadBajada  Int     @map("velocidad_bajada")
  velocidadSubida  Int     @map("velocidad_subida")
  precio           Decimal @db.Decimal(12, 2)
  iva              Decimal @default(0) @db.Decimal(5, 2)
  tecnologia       String
  activo           Boolean @default(true)
  creadoEn         DateTime @default(now()) @map("creado_en")

  servicios Servicio[]

  @@map("plan")
}

/// La "línea" de internet: conecta cliente + punto + plan. Bloques 3 y 4.
/// Un cliente puede tener varios servicios (1→N), aunque el form crea uno.
model Servicio {
  id        String           @id @default(uuid()) @db.Uuid
  clienteId String           @map("cliente_id") @db.Uuid
  cliente   Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  puntoId   String           @map("punto_id") @db.Uuid
  punto     PuntoInstalacion @relation(fields: [puntoId], references: [id], onDelete: Cascade)
  planId    String?          @map("plan_id") @db.Uuid
  plan      Plan?            @relation(fields: [planId], references: [id])

  // Plan/datos técnicos (bloque 3) — denormalizado en P0
  planNombre      String  @map("plan_nombre")
  velocidadBajada Int?    @map("velocidad_bajada")
  velocidadSubida Int?    @map("velocidad_subida")
  tecnologia      String
  napId           String? @map("nap_id")
  puerto          Int?
  onuSerial       String? @map("onu_serial")
  ip              String?
  vlan            Int?
  usuarioPppoe    String? @map("usuario_pppoe") // se usa en P2 (RADIUS)
  fechaInstalacion DateTime? @map("fecha_instalacion") @db.Date
  estado          String  @default("instalacion_pendiente") // máquina de estados

  // Facturación y contrato (bloque 4) — denormalizado en P0
  cicloFacturacion    String?  @map("ciclo_facturacion")
  diaCorte            Int?     @map("dia_corte")
  metodoPago          String?  @map("metodo_pago")
  tarifa              Decimal? @db.Decimal(12, 2)
  saldo               Decimal? @db.Decimal(12, 2)
  numeroContrato      String?  @map("numero_contrato")
  fechaInicioContrato DateTime? @map("fecha_inicio_contrato") @db.Date
  fechaFinContrato    DateTime? @map("fecha_fin_contrato") @db.Date

  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  facturas Factura[]

  @@map("servicio")
}

/// Esqueleto de factura — se desarrolla en P1.
model Factura {
  id               String   @id @default(uuid()) @db.Uuid
  servicioId       String   @map("servicio_id") @db.Uuid
  servicio         Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  periodo          String // "2026-06"
  subtotal         Decimal  @db.Decimal(12, 2)
  iva              Decimal  @default(0) @db.Decimal(12, 2)
  total            Decimal  @db.Decimal(12, 2)
  estado           String   @default("pendiente") // pendiente|pagada|vencida|anulada
  fechaEmision     DateTime @map("fecha_emision") @db.Date
  fechaVencimiento DateTime @map("fecha_vencimiento") @db.Date
  pdfUrl           String?  @map("pdf_url")
  creadoEn         DateTime @default(now()) @map("creado_en")

  pagos Pago[]

  @@map("factura")
}

/// Esqueleto de pago — se desarrolla en P3.
model Pago {
  id                String   @id @default(uuid()) @db.Uuid
  facturaId         String   @map("factura_id") @db.Uuid
  factura           Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  monto             Decimal  @db.Decimal(12, 2)
  metodo            String // wompi|efectivo|transferencia|...
  referenciaExterna String?  @unique @map("referencia_externa") // idempotencia
  estado            String   @default("pendiente") // aprobado|rechazado|pendiente
  pagadoEn          DateTime? @map("pagado_en")
  creadoEn          DateTime @default(now()) @map("creado_en")

  @@map("pago")
}

/// Transacción de pasarela (Wompi). Fuente de verdad del ciclo de pago en línea,
/// desacoplada de la facturación (P1): existe aunque aún no haya factura formal.
/// Cuando hay factura, se enlaza (facturaId) y al aprobarse se marca pagada.
model PagoTransaccion {
  id            String   @id @default(uuid()) @db.Uuid
  /// Referencia única que enviamos a Wompi (idempotencia).
  referencia    String   @unique
  proveedor     String   @default("wompi")
  /// Id de la transacción en Wompi (se llena al confirmar).
  proveedorTxId String?  @map("proveedor_tx_id")
  montoCents    Int      @map("monto_cents")
  moneda        String   @default("COP")
  /// CREADA | PENDIENTE | APROBADA | RECHAZADA | ANULADA | ERROR
  estado        String   @default("CREADA")
  metodo        String? // PSE | NEQUI | CARD | BANCOLOMBIA_TRANSFER | ...
  descripcion   String?
  emailCliente  String?  @map("email_cliente")
  facturaId     String?  @map("factura_id") @db.Uuid
  clienteId     String?  @map("cliente_id") @db.Uuid
  creadoPor     String?  @map("creado_por")
  datosWompi    Json?    @map("datos_wompi") @db.JsonB
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  @@map("pago_transaccion")
}

/// Ticket de soporte (lo puede crear el asistente "Cica" o el staff).
model Ticket {
  id          String   @id @default(uuid()) @db.Uuid
  codigo      String   @unique // TCK-XXXX visible
  asunto      String
  descripcion String
  categoria   String   @default("general") // tecnico|facturacion|comercial|general
  contacto    String? // nombre/teléfono que dejó el cliente
  estado      String   @default("abierto") // abierto|en_proceso|resuelto|cerrado
  origen      String   @default("asistente") // asistente|panel|whatsapp
  creadoPor   String?  @map("creado_por") // username de quien lo originó (cliente/staff)
  clienteId   String?  @map("cliente_id") @db.Uuid
  creadoEn    DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  @@index([estado])
  @@map("ticket")
}

/// Orden de trabajo de campo (instalación / visita / reparación). El admin u
/// operador la crea y la asigna a un técnico (por su username); el técnico la
/// gestiona desde su apartado en la app móvil: cambia el estado, adjunta fotos
/// de evidencia (capturadas con la cámara) y la completa con notas. El admin NO
/// sube fotos: la evidencia la genera el técnico en sitio.
model OrdenTrabajo {
  id              String   @id @default(uuid()) @db.Uuid
  codigo          String   @unique // OT-XXXX visible
  tipo            String   @default("instalacion") // instalacion|visita|reparacion
  estado          String   @default("asignada") // asignada|en_camino|en_sitio|completada|cancelada
  prioridad       String   @default("media") // baja|media|alta

  titulo          String
  descripcion     String?
  direccion       String
  lat             Float?
  lng             Float?

  /// Username del técnico asignado (rol `tecnico`). null = sin asignar.
  tecnico         String?
  /// Vínculo opcional al cliente (UUID). La OT puede existir antes del alta.
  clienteId       String?  @map("cliente_id") @db.Uuid
  clienteNombre   String?  @map("cliente_nombre")
  contacto        String? // teléfono/nombre de contacto en sitio

  fechaProgramada DateTime? @map("fecha_programada")
  notasTecnico    String?  @map("notas_tecnico")
  /// Evidencia fotográfica: [{ id, url, nota, ts }]. La suben los técnicos.
  fotos           Json?    @db.JsonB
  /// Bitácora de cambios de estado: [{ estado, ts, por }].
  historial       Json?    @db.JsonB

  creadoPor       String?  @map("creado_por")
  creadoEn        DateTime @default(now()) @map("creado_en")
  completadaEn    DateTime? @map("completada_en")
  actualizadoEn   DateTime? @updatedAt @map("actualizado_en")

  @@index([tecnico])
  @@index([estado])
  @@map("orden_trabajo")
}

/// Configuración clave/valor de la plataforma (editable desde el panel admin).
/// Ej.: "soporte_whatsapp" → { numero, mensaje, habilitado }. Reutilizable para
/// futuras configuraciones (config_facturacion, etc.) sin nuevas migraciones.
model Setting {
  clave         String   @id
  valor         Json     @db.JsonB
  actualizadoPor String? @map("actualizado_por")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("setting")
}

/// Bitácora de auditoría: todo cambio sensible (quién, qué, cuándo).
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actor     String? // username del staff (del JWT)
  accion    String // create|update|delete
  entidad   String // "cliente", ...
  entidadId String?  @map("entidad_id")
  diff      Json?    @db.JsonB
  ts        DateTime @default(now())

  @@index([entidad, entidadId])
  @@map("audit_log")
}

// ============================================================
//  Gemelo Digital de la Red (network-digital-twin) — inventario en Postgres.
//  Migrado desde JSON (infra-*.json) a la BD para integridad, transacciones y
//  fuente de verdad única junto al CRM. La geometría se guarda como lat/lng
//  (Float) + trazado (Json); las columnas PostGIS/índices GIST se añaden cuando
//  se muevan las consultas espaciales del JS al motor. Ids con prefijo de
//  dominio (NAP-001, POP-001, FIB-001) — públicos y estables.
// ============================================================

/// Activo de red/planta: POP, OLT, NAP, Splitter, Cliente, etc. Ficha universal.
model Activo {
  id            String   @id // NAP-001, POP-001, ...
  tipo          String
  nombre        String
  marca         String?
  modelo        String?
  serie         String?
  direccion     String?
  barrio        String?
  comuna        String?
  ciudad        String?
  lat           Float
  lng           Float
  estado        String   @default("Activo")
  propio        Boolean  @default(true)
  regimen       String?
  /// Topología: de qué activo depende (grafo padre→hijo).
  padreId       String?  @map("padre_id")
  sitioId       String?  @map("sitio_id")
  /// Plan mensual (COP) cuando el activo es un Cliente — base de ingresos.
  planMensual   Float?   @map("plan_mensual")
  /// Atributos por tipo (puertosTotal/Usados de NAP, etc.).
  atributos     Json?    @db.JsonB
  /// Evidencia fotográfica [{ id, categoria, url, subidoEn, autor }].
  fotos         Json?    @db.JsonB
  documentos    Json?    @db.JsonB
  historial     Json?    @db.JsonB
  creadoPor     String?  @map("creado_por")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime? @updatedAt @map("actualizado_en")

  @@index([tipo])
  @@index([padreId])
  @@map("activo")
}

/// Segmento de fibra: trayecto físico entre dos puntos/activos.
model SegmentoFibra {
  id               String   @id // FIB-001
  nombre           String?
  tipoFibra        String?  @map("tipo_fibra")
  hilos            Int?
  origenId         String?  @map("origen_id")
  destinoId        String?  @map("destino_id")
  origenDireccion  String?  @map("origen_direccion")
  destinoDireccion String?  @map("destino_direccion")
  origenLng        Float    @map("origen_lng")
  origenLat        Float    @map("origen_lat")
  destinoLng       Float    @map("destino_lng")
  destinoLat       Float    @map("destino_lat")
  /// Trazado [[lng,lat], ...].
  trazado          Json?    @db.JsonB
  longitud         Float // metros
  creadoPor        String?  @map("creado_por")
  creadoEn         DateTime @default(now()) @map("creado_en")

  @@map("segmento_fibra")
}

/// Sitio físico (POP, nodo, gabinete) que agrupa activos.
model Sitio {
  id         String   @id // SITE-001
  nombre     String
  lat        Float
  lng        Float
  activosIds Json?    @map("activos_ids") @db.JsonB
  creadoEn   DateTime @default(now()) @map("creado_en")

  @@map("sitio")
}
