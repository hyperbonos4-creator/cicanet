# ============================================================
#  CICANET · Variables del stack Docker (copiar a .env)
#  TODO tiene default — solo defínelas para sobrescribir.
#  cp .env.example .env
# ============================================================

# --- Postgres / PostGIS ---
POSTGRES_USER=cicanet
POSTGRES_PASSWORD=cicanet_dev
POSTGRES_DB=cicanet

# --- MinIO (S3) ---
MINIO_USER=cicanet
MINIO_PASSWORD=cicanet_dev

# --- API ---
CORS_ORIGINS=http://localhost:3000
SEED_ADMIN_USER=admin
SEED_ADMIN_PASS=cicanet2026

# --- Demo público efímero (VISIONYX Telecom) ---
# SOLO se activa en el despliegue de demostración. En el ISP real déjalo en false
# (el endpoint /api/demo/session responde 403). En el demo: DEMO_MODE=true y agrega
# los orígenes del sitio a CORS_ORIGINS (https://visionyx.lat,https://www.visionyx.lat).
DEMO_MODE=false
DEMO_TTL_MINUTES=60
DEMO_MAX_ACTIVE_SESSIONS=40
DEMO_SWEEP_SECONDS=60
DEMO_ROLE=admin
# URL pública de la web del demo (a donde el sitio envía al visitante a iniciar sesión).
DEMO_APP_URL=https://demo-telecom.visionyx.lat

# --- Geocodificación ---
# 'mapbox' = automático y preciso a nivel de casa (requiere token gratuito de mapbox.com).
# 'nominatim' = OpenStreetMap, sin clave, precisión a nivel de calle.
GEOCODER_PROVIDER=mapbox
# Pega aquí tu token gratuito de Mapbox (https://account.mapbox.com/access-tokens/):
MAPBOX_TOKEN=
# CAMBIAR en producción por valores largos y aleatorios:
JWT_ACCESS_SECRET=cicanet-dev-access-secret-change-me
JWT_REFRESH_SECRET=cicanet-dev-refresh-secret-change-me

# --- Web (URLs accesibles desde el navegador del host) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000/realtime

# --- Asistente / Chatbot (mismo modelo que la web de access: GLM en Cloudflare) ---
# Por defecto usa GLM (Cloudflare Workers AI) con ROTACIÓN sobre el pool de
# cuentas en cuentas/cuentas.json (el contenedor lo lee de /workspace).
ASSISTANT_PROVIDER=cloudflare
ASSISTANT_MODEL=@cf/zai-org/glm-4.7-flash
ASSISTANT_DISABLE_THINKING=true
ASSISTANT_ACCOUNTS_FILE=/workspace/cuentas/cuentas.json
# Alternativa: cuenta única (sin rotación). Ej. Gemini:
#   ASSISTANT_PROVIDER=gemini
#   ASSISTANT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   ASSISTANT_API_KEY=...
#   ASSISTANT_MODEL=gemini-2.0-flash
